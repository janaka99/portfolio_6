generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  passwordHash     String
  name             String?
  resetToken       String?
  resetTokenExpiry DateTime?
}

model project {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  content      String?
  livelink     String?
  githublink   String?
  technologies String[]
  tags         Json?    @map("tags")
  cover        String?
  images       String[]
  order        Int      @default(0)
  published    Boolean  @default(false)
  category     String?  @default("AI")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt()
}
